var style_Eib_Ejes_0 = function(feature, resolution){
    var context = {
        feature: feature,
        variables: {}
    };

    // 1. Extraer campos y solucionar el bug del texto original de qgis2web
    var etiquetaSIGLA = feature.get("EibCcl_Callejero_eibTipVia") != null ? String(feature.get("EibCcl_Callejero_eibTipVia")) : '';
    var etiquetaNOMVIA = feature.get("EibCcl_Callejero_eibNomVia") != null ? String(feature.get("EibCcl_Callejero_eibNomVia")) : '';

    var labelText = "";
    if (etiquetaSIGLA.trim() !== "") {
        labelText += etiquetaSIGLA + " ";
    }
    labelText += etiquetaNOMVIA;
    labelText = String(labelText).trim();

    var value = feature.get("eibCodVia");

    // Configuración base del diseño del texto para los ejes
    var labelFont = "bold 12px 'Open Sans', sans-serif";
    var labelFill = "#1a1a1a";
    var bufferColor = "#ffffff";
    var bufferWidth = 3;
    var textAlign = "center";
    var offsetX = 0;
    var offsetY = 0;
    var placement = 'line';

    // =========================================================================
    // AISLAMIENTO: MODIFICAMOS LA FUNCIÓN GLOBAL SOLO PARA ESTA LLAMADA
    // =========================================================================
    var originalCreateTextStyle = window.createTextStyle;

    window.createTextStyle = function(f, res, lText, lFont, lFill, plac, bColor, bWidth) {
        // Control de zoom (exclusivo para los ejes)
        var zoomActual = (typeof map !== 'undefined') ? map.getView().getZoom() : 18;
        if (zoomActual < 18) {
            lText = "";
        }

        // Ejecutamos el constructor base original
        var oldStyle = originalCreateTextStyle(f, res, lText, lFont, lFill, plac, bColor, bWidth);

        if (oldStyle && lText !== "") {
            return new ol.style.Text({
                text: oldStyle.getText(),
                font: oldStyle.getFont(),
                fill: oldStyle.getFill(),
                stroke: oldStyle.getStroke(),
                textAlign: oldStyle.getTextAlign(),
                textBaseline: 'middle',
                offsetX: oldStyle.getOffsetX(),
                offsetY: oldStyle.getOffsetY(),

                // Forzamos las propiedades de trazado continuo en la línea
                placement: 'line',
                repeat: 1000,
                overflow: true
            });
        }
        return oldStyle;
    };
    // =========================================================================

    // 2. Se ejecutan las categorías de los ejes (usará la función modificada temporalmente)
    var style = categories_Eib_Ejes_0(feature, value, size, resolution, labelText,
                            labelFont, labelFill, bufferColor,
                            bufferWidth, placement);

    // =========================================================================
    // RESTAURACIÓN INMEDIATA: Devolvemos el mapa a la normalidad absoluta
    // =========================================================================
    window.createTextStyle = originalCreateTextStyle;
    // =========================================================================

    return style;
};


